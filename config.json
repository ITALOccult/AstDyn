{
  "integrator": {
    "type": "OrbFitDP",
    "initial_step": 0.1,
    "tolerance": 1e-12,
    "min_step": 1e-6,
    "max_step": 5.0
  },
  "propagator": {
    "include_planets": true,
    "include_relativity": true,
    "include_moon": true,
    "integrate_in_ecliptic": true,
    "perturb_mercury": true,
    "perturb_venus": true,
    "perturb_earth": true,
    "perturb_mars": true,
    "perturb_jupiter": true,
    "perturb_saturn": true,
    "perturb_uranus": true,
    "perturb_neptune": true
  },
  "differential_corrector": {
    "max_iterations": 30,
    "convergence_tolerance_au": 1e-9,
    "outlier_sigma": 5.0,
    "outlier_max_sigma": 100.0,
    "outlier_min_sigma": 3.0,
    "reject_outliers": true,
    "use_line_search": true
  }
}
